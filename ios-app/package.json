{
  "name": "EVRoutePlanner",
  "version": "1.0.0",
  "private": true,
  "description": "EV Route & Charging Planner — plan your electric vehicle journey with smart charging stops (iOS-only project, separated from the Android version)",
  "scripts": {
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.22.3",
    "@react-native-community/slider": "^4.5.2",
    "@react-native-community/blur": "^4.4.1",
    "@react-native-picker/picker": "^2.6.1",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.10",
    "@react-navigation/native-stack": "^6.9.17",
    "axios": "^1.6.5",
    "react": "18.3.1",
    "react-hook-form": "^7.50.1",
    "react-native": "0.76.5",
    "react-native-config": "^1.5.1",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-maps": "^1.20.1",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-screens": "^3.29.0",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-vector-icons": "^10.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native-community/cli": "15.1.3",
    "@react-native/babel-preset": "0.76.5",
    "@react-native/eslint-config": "0.76.5",
    "@react-native/metro-config": "0.76.5",
    "@react-native/typescript-config": "0.76.5",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.6",
    "@types/react-native-sqlite-storage": "^6.0.4",
    "@types/react-test-renderer": "^18.0.7",
    "babel-jest": "^29.6.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "18.3.1",
    "typescript": "5.0.4"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-native-maps|react-native-vector-icons|react-native-sqlite-storage|react-native-config|react-native-geolocation-service|react-native-safe-area-context|react-native-screens|react-native-linear-gradient)/)"
    ],
    "setupFiles": [
      "./jest.setup.js"
    ],
    "moduleNameMapper": {
      "^react-native-config$": "<rootDir>/__mocks__/react-native-config.js",
      "^react-native-sqlite-storage$": "<rootDir>/__mocks__/react-native-sqlite-storage.js",
      "^react-native-maps$": "<rootDir>/__mocks__/react-native-maps.js",
      "^react-native-geolocation-service$": "<rootDir>/__mocks__/react-native-geolocation-service.js",
      "^@react-native-community/slider$": "<rootDir>/__mocks__/@react-native-community/slider.js"
    }
  }
}
